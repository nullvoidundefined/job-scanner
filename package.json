{
  "name": "job-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal early-stage company radar and networking CRM",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.2.5",
    "helmet": "^8.1.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^3.2.4",
    "lefthook": "^2.1.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
