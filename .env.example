# development | production | staging | test
NODE_ENV=development

# Server port
PORT=3001

# Database (e.g. Neon, local Postgres). Rotate credentials if ever exposed.
DATABASE_URL=postgresql://user:password@host:5432/dbname
# PEM-encoded CA certificate for verified SSL. Set when your provider uses a
# custom CA (e.g. Neon, RDS). Omit for local dev or Railway private networking.
# DATABASE_CA_CERT=

# Single-secret gate guarding the CRM (it holds contact PII).
# Generate with: openssl rand -hex 32
APP_SECRET=change-me

# EDGAR fair-access: a descriptive User-Agent with a REAL contact is mandatory
# under the SEC data-access policy (sec.gov/os/accessing-edgar-data).
SEC_USER_AGENT=job-scanner you@example.com

# Weekly digest email (Resend). Optional until the digest job is wired.
# RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=radar@example.com
# DIGEST_TO_EMAIL=you@example.com

# Telegram alerts: heartbeat, board-health, hot-match. Optional.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# AI-native enrichment (Phase 2, Anthropic Haiku). Optional.
# ANTHROPIC_API_KEY=sk-ant-...
